#include <windows.h>
#include "resource.h"

// Tell the resource compiler to use UTF-8 encoding
#pragma code_page(65001)

// English (United States) resources
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

// Menu
IDR_MENU_MAIN MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N", ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O", ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "&Read-Only", ID_FILE_READONLY
        MENUITEM SEPARATOR
        MENUITEM "&Save\tCtrl+S", ID_FILE_SAVE
        MENUITEM "Save &As...", ID_FILE_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tAlt+F4", ID_FILE_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z", ID_EDIT_UNDO
        MENUITEM "&Redo\tCtrl+Y", ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X", ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C", ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V", ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A", ID_EDIT_SELECTALL
        MENUITEM SEPARATOR
        MENUITEM "Time/&Date\tF5", ID_EDIT_TIMEDATE
    END
    POPUP "&Search"
    BEGIN
        MENUITEM "&Find...\tCtrl+F", ID_SEARCH_FIND
        MENUITEM "&Replace...\tCtrl+H", ID_SEARCH_REPLACE
        MENUITEM "Find &Next\tF3", ID_SEARCH_FIND_NEXT
        MENUITEM "Find &Previous\tShift+F3", ID_SEARCH_FIND_PREVIOUS
        MENUITEM SEPARATOR
        MENUITEM "&Go to Line...\tCtrl+G", ID_SEARCH_GOTO_LINE
        MENUITEM SEPARATOR
        MENUITEM "Toggle &Bookmark\tCtrl+F2", ID_SEARCH_TOGGLE_BOOKMARK
        MENUITEM "&Next Bookmark\tF2", ID_SEARCH_NEXT_BOOKMARK
        MENUITEM "&Previous Bookmark\tShift+F2", ID_SEARCH_PREV_BOOKMARK
        MENUITEM "&Clear All Bookmarks", ID_SEARCH_CLEAR_BOOKMARKS
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Word Wrap\tCtrl+W", ID_VIEW_WORDWRAP
        MENUITEM "&Reset Zoom\tCtrl+0", ID_VIEW_ZOOM_RESET
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Execute Filter\tCtrl+Enter", ID_TOOLS_EXECUTEFILTER, GRAYED
        MENUITEM "&Start Interactive Mode\tCtrl+Shift+I", ID_TOOLS_START_INTERACTIVE, GRAYED
        MENUITEM "E&xit Interactive Mode\tCtrl+Shift+Q", ID_TOOLS_EXIT_INTERACTIVE, GRAYED
        MENUITEM SEPARATOR
        POPUP "Select &Filter"
        BEGIN
            MENUITEM "(No filters configured)", ID_TOOLS_FILTER_BASE, GRAYED
        END
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...", ID_HELP_ABOUT
    END
END

// About Dialog
IDD_ABOUT DIALOGEX 0, 0, 240, 178
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About RichEditor"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    ICON IDI_APPLICATION, IDC_STATIC, 10, 10, 20, 20
    LTEXT "RichEditor v2.8.0", IDC_STATIC, 40, 10, 190, 12, SS_NOPREFIX
    LTEXT "Lightweight, accessible Win32 plain-text editor", IDC_STATIC, 40, 25, 190, 10
    LTEXT "Copyright (C) 2025-2026 PEERSOFT", IDC_STATIC, 40, 37, 190, 10
    LTEXT "", IDC_STATIC, 10, 49, 220, 1, SS_ETCHEDHORZ
    LTEXT "", IDC_RICHEDIT_VERSION, 40, 53, 190, 10  // RichEdit version+class (filled at runtime)
    LTEXT "", IDC_RICHEDIT_VERSION_PATH, 40, 65, 190, 10  // RichEdit DLL path (filled at runtime)
    LTEXT "", IDC_STATIC, 10, 77, 220, 1, SS_ETCHEDHORZ
    LTEXT "Key features:", IDC_STATIC, 10, 83, 220, 10
    LTEXT "• UTF-8 plain text (no BOM) · autosave on timer and focus loss", IDC_STATIC, 20, 95, 210, 10
    LTEXT "• Word wrap · visual Ln/Col status · Go to Line", IDC_STATIC, 20, 106, 210, 10
    LTEXT "• Find/Replace with history, undo, and escape sequences", IDC_STATIC, 20, 117, 210, 10
    LTEXT "• External filter/pipe system · template insertion (F5)", IDC_STATIC, 20, 128, 210, 10
    LTEXT "• Elevated save (UAC) · optional session resume", IDC_STATIC, 20, 139, 210, 10
    LTEXT "• English + Czech UI · screen reader accessible", IDC_STATIC, 20, 150, 210, 10
    DEFPUSHBUTTON "OK", IDOK, 95, 162, 50, 14
END

// Find dialog (Phase 2.9)
IDD_FIND DIALOGEX 0, 0, 260, 120
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Find"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    LTEXT           "Find &what:", IDC_STATIC, 7, 10, 50, 8
    COMBOBOX        IDC_FIND_WHAT, 60, 8, 130, 100, CBS_DROPDOWN | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Replace &with:", IDC_REPLACE_WITH_LABEL, 7, 28, 50, 8
    COMBOBOX        IDC_REPLACE_WITH, 60, 26, 130, 100, CBS_DROPDOWN | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "Find &Next →", IDC_FIND_NEXT_BTN, 197, 7, 56, 14
    PUSHBUTTON      "Find &Previous ←", IDC_FIND_PREV_BTN, 197, 24, 56, 14
    PUSHBUTTON      "&Replace", IDC_REPLACE_BTN, 197, 42, 56, 14
    PUSHBUTTON      "Replace &All", IDC_REPLACE_ALL_BTN, 197, 59, 56, 14
    PUSHBUTTON      "Close", IDC_CLOSE_BTN, 197, 99, 56, 14
    AUTOCHECKBOX    "Match &case", IDC_MATCH_CASE, 7, 48, 80, 10
    AUTOCHECKBOX    "&Whole word", IDC_WHOLE_WORD, 7, 63, 80, 10
    AUTOCHECKBOX    "Use &escape sequences (\\n, \\t, \\xNN, \\uNNNN)", IDC_USE_ESCAPES, 7, 78, 180, 10
END

// Go to Line dialog (Phase 2.9.4)
IDD_GOTO DIALOGEX 0, 0, 200, 80
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Go to Line"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    LTEXT           "", IDC_GOTO_LABEL, 10, 12, 180, 8
    EDITTEXT        IDC_GOTO_LINE, 10, 25, 180, 14, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON   "Go", IDOK, 55, 50, 40, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 105, 50, 40, 14
END

// Version Information
VS_VERSION_INFO VERSIONINFO
FILEVERSION     2,8,0,0
PRODUCTVERSION  2,8,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS   VS_FF_DEBUG
#else
    FILEFLAGS   0x0L
#endif
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"  // English (US), Unicode
        BEGIN
            VALUE "CompanyName",      "PEERSOFT"
            VALUE "FileDescription",  "RichEditor - Lightweight Text Editor"
            VALUE "FileVersion",      "2.8.0.0"
            VALUE "InternalName",     "RichEditor"
            VALUE "LegalCopyright",   "Copyright (C) 2025-2026 PEERSOFT"
            VALUE "OriginalFilename", "RichEditor.exe"
            VALUE "ProductName",      "RichEditor"
            VALUE "ProductVersion",   "2.8.0"
            VALUE "Comments",         "Accessible plain-text editor with UTF-8, autosave, word wrap, find/replace, filters, elevated save, and English+Czech UI. Built with MinGW-w64 or MSVC."
        END
        BLOCK "040504B0"  // Czech, Unicode
        BEGIN
            VALUE "CompanyName",      "PEERSOFT"
            VALUE "FileDescription",  "RichEditor - Lehký textový editor"
            VALUE "FileVersion",      "2.8.0.0"
            VALUE "InternalName",     "RichEditor"
            VALUE "LegalCopyright",   "Copyright (C) 2025-2026 PEERSOFT"
            VALUE "OriginalFilename", "RichEditor.exe"
            VALUE "ProductName",      "RichEditor"
            VALUE "ProductVersion",   "2.8.0"
            VALUE "Comments",         "Přístupný editor prostého textu s UTF-8, automatickým ukládáním, zalamováním řádků, hledáním/nahrazením, filtry, ukládáním se zvýšenými právy a anglickým+českým UI."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0, 0x0405, 0x04B0
    END
END

