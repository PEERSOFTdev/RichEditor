#include <windows.h>
#include "resource.h"

// Tell the resource compiler to use UTF-8 encoding
#pragma code_page(65001)

// English (United States) resources
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

// Menu
IDR_MENU_MAIN MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N", ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O", ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S", ID_FILE_SAVE
        MENUITEM "Save &As...", ID_FILE_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tAlt+F4", ID_FILE_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z", ID_EDIT_UNDO
        MENUITEM "&Redo\tCtrl+Y", ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X", ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C", ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V", ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A", ID_EDIT_SELECTALL
        MENUITEM SEPARATOR
        MENUITEM "Time/&Date\tF5", ID_EDIT_TIMEDATE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Word Wrap\tCtrl+W", ID_VIEW_WORDWRAP
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Execute Filter\tCtrl+Enter", ID_TOOLS_EXECUTEFILTER, GRAYED
        MENUITEM "&Start Interactive Mode\tCtrl+Shift+I", ID_TOOLS_START_INTERACTIVE, GRAYED
        MENUITEM "E&xit Interactive Mode\tCtrl+Shift+Q", ID_TOOLS_EXIT_INTERACTIVE, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "Filter &Help...", ID_TOOLS_FILTER_HELP
        MENUITEM SEPARATOR
        POPUP "Select &Filter"
        BEGIN
            MENUITEM "(No filters configured)", ID_TOOLS_FILTER_BASE, GRAYED
        END
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...", ID_HELP_ABOUT
    END
END

// Accelerators
IDR_ACCELERATOR ACCELERATORS
BEGIN
    "N", ID_FILE_NEW, VIRTKEY, CONTROL
    "O", ID_FILE_OPEN, VIRTKEY, CONTROL
    "S", ID_FILE_SAVE, VIRTKEY, CONTROL
    "Z", ID_EDIT_UNDO, VIRTKEY, CONTROL
    "Y", ID_EDIT_REDO, VIRTKEY, CONTROL
    "X", ID_EDIT_CUT, VIRTKEY, CONTROL
    "C", ID_EDIT_COPY, VIRTKEY, CONTROL
    "V", ID_EDIT_PASTE, VIRTKEY, CONTROL
    "A", ID_EDIT_SELECTALL, VIRTKEY, CONTROL
    "W", ID_VIEW_WORDWRAP, VIRTKEY, CONTROL
    VK_F5, ID_EDIT_TIMEDATE, VIRTKEY
    VK_RETURN, ID_TOOLS_EXECUTEFILTER, VIRTKEY, CONTROL
    "I", ID_TOOLS_START_INTERACTIVE, VIRTKEY, CONTROL, SHIFT
    "Q", ID_TOOLS_EXIT_INTERACTIVE, VIRTKEY, CONTROL, SHIFT
END

// About Dialog
IDD_ABOUT DIALOGEX 0, 0, 240, 120
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About RichEditor"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    ICON IDI_APPLICATION, IDC_STATIC, 10, 10, 20, 20
    LTEXT "RichEditor v1.0.0", IDC_STATIC, 40, 10, 190, 12, SS_NOPREFIX
    LTEXT "A lightweight, accessible text editor", IDC_STATIC, 40, 25, 190, 10
    LTEXT "Built with MinGW-w64 and RichEdit 4.1", IDC_STATIC, 40, 38, 190, 10
    LTEXT "", IDC_STATIC, 10, 55, 220, 1, SS_ETCHEDHORZ
    LTEXT "Features:", IDC_STATIC, 10, 62, 220, 10
    LTEXT "• UTF-8 text editing with autosave", IDC_STATIC, 20, 75, 210, 10
    LTEXT "• Word wrap with position tracking", IDC_STATIC, 20, 87, 210, 10
    DEFPUSHBUTTON "OK", IDOK, 95, 100, 50, 14
END

// Version Information
VS_VERSION_INFO VERSIONINFO
FILEVERSION     2,6,0,0
PRODUCTVERSION  2,6,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS   VS_FF_DEBUG
#else
    FILEFLAGS   0x0L
#endif
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"  // English (US), Unicode
        BEGIN
            VALUE "CompanyName",      "PEERSOFT"
            VALUE "FileDescription",  "RichEditor - Lightweight Text Editor"
            VALUE "FileVersion",      "2.6.0.0"
            VALUE "InternalName",     "RichEditor"
            VALUE "LegalCopyright",   "Copyright (C) 2025-2026 PEERSOFT"
            VALUE "OriginalFilename", "RichEditor.exe"
            VALUE "ProductName",      "RichEditor"
            VALUE "ProductVersion",   "2.6.0 (Session Resume)"
            VALUE "Comments",         "Accessible text editor with RichEdit 4.1 control, autosave, word wrap, and filter support. Built with MinGW-w64."
        END
        BLOCK "040504B0"  // Czech, Unicode
        BEGIN
            VALUE "CompanyName",      "PEERSOFT"
            VALUE "FileDescription",  "RichEditor - Lehký textový editor"
            VALUE "FileVersion",      "2.6.0.0"
            VALUE "InternalName",     "RichEditor"
            VALUE "LegalCopyright",   "Copyright (C) 2025-2026 PEERSOFT"
            VALUE "OriginalFilename", "RichEditor.exe"
            VALUE "ProductName",      "RichEditor"
            VALUE "ProductVersion",   "2.6.0 (Obnovení relace)"
            VALUE "Comments",         "Přístupný textový editor s ovládacím prvkem RichEdit 4.1, automatickým ukládáním, zalamováním řádků a podporou filtrů. Vytvořeno pomocí MinGW-w64."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0, 0x0405, 0x04B0
    END
END

