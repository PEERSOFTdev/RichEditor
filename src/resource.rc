// ============================================================================
LANGUAGE LANG_CZECH, SUBLANG_DEFAULT

// Menu
IDR_MENU_MAIN MENU
BEGIN
    POPUP "&Soubor"
    BEGIN
        MENUITEM "&Nový\tCtrl+N", ID_FILE_NEW
        MENUITEM "&Otevřít...\tCtrl+O", ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "&Pouze ke čtení", ID_FILE_READONLY
        MENUITEM SEPARATOR
        MENUITEM "&Uložit\tCtrl+S", ID_FILE_SAVE
        MENUITEM "Uložit j&ako...", ID_FILE_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "&Konec\tAlt+F4", ID_FILE_EXIT
    END
    POPUP "Úp&ravy"
    BEGIN
        MENUITEM "&Zpět\tCtrl+Z", ID_EDIT_UNDO
        MENUITEM "Z&novu\tCtrl+Y", ID_EDIT_REDO
        MENUITEM SEPARATOR
        MENUITEM "Vyjmou&t\tCtrl+X", ID_EDIT_CUT
        MENUITEM "&Kopírovat\tCtrl+C", ID_EDIT_COPY
        MENUITEM "&Vložit\tCtrl+V", ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "Vybrat vš&e\tCtrl+A", ID_EDIT_SELECTALL
        MENUITEM SEPARATOR
        MENUITEM "Čas a &datum\tF5", ID_EDIT_TIMEDATE
    END
    POPUP "&Hledat"
    BEGIN
        MENUITEM "&Najít...\tCtrl+F", ID_SEARCH_FIND
        MENUITEM "N&ahradit...\tCtrl+H", ID_SEARCH_REPLACE
        MENUITEM "Najít &další\tF3", ID_SEARCH_FIND_NEXT
        MENUITEM "Najít &předchozí\tShift+F3", ID_SEARCH_FIND_PREVIOUS
        MENUITEM SEPARATOR
        MENUITEM "&Přejít na řádek...\tCtrl+G", ID_SEARCH_GOTO_LINE
        MENUITEM SEPARATOR
        MENUITEM "Přepnout &záložku\tCtrl+F2", ID_SEARCH_TOGGLE_BOOKMARK
        MENUITEM "&Další záložka\tF2", ID_SEARCH_NEXT_BOOKMARK
        MENUITEM "&Předchozí záložka\tShift+F2", ID_SEARCH_PREV_BOOKMARK
        MENUITEM "&Smazat všechny záložky", ID_SEARCH_CLEAR_BOOKMARKS
    END
    POPUP "&Zobrazit"
    BEGIN
        MENUITEM "&Zalamování řádků\tCtrl+W", ID_VIEW_WORDWRAP
        MENUITEM "&Obnovit přiblížení\tCtrl+0", ID_VIEW_ZOOM_RESET
    END
    POPUP "&Nástroje"
    BEGIN
        MENUITEM "&Spustit filtr\tCtrl+Enter", ID_TOOLS_EXECUTEFILTER, GRAYED
        MENUITEM "S&pustit interaktivní režim\tCtrl+Shift+I", ID_TOOLS_START_INTERACTIVE, GRAYED
        MENUITEM "&Ukončit interaktivní režim\tCtrl+Shift+Q", ID_TOOLS_EXIT_INTERACTIVE, GRAYED
        MENUITEM SEPARATOR
        POPUP "Vybrat &filtr"
        BEGIN
            MENUITEM "(Žádné filtry nejsou nakonfigurovány)", ID_TOOLS_FILTER_BASE, GRAYED
        END
    END
    POPUP "&Nápověda"
    BEGIN
        MENUITEM "&O programu...", ID_HELP_ABOUT
    END
END

// About Dialog
IDD_ABOUT DIALOGEX 0, 0, 240, 178
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "O programu RichEditor"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    ICON IDI_APPLICATION, IDC_STATIC, 10, 10, 20, 20
    LTEXT "RichEditor v2.8.0", IDC_STATIC, 40, 10, 190, 12, SS_NOPREFIX
    LTEXT "Lehký, přístupný editor prostého textu Win32", IDC_STATIC, 40, 25, 190, 10
    LTEXT "Copyright (C) 2025-2026 PEERSOFT", IDC_STATIC, 40, 37, 190, 10
    LTEXT "", IDC_STATIC, 10, 49, 220, 1, SS_ETCHEDHORZ
    LTEXT "", IDC_RICHEDIT_VERSION, 40, 53, 190, 10  // Verze+třída RichEdit (vyplněno při běhu)
    LTEXT "", IDC_RICHEDIT_VERSION_PATH, 40, 65, 190, 10  // Cesta k DLL RichEdit (vyplněno při běhu)
    LTEXT "", IDC_STATIC, 10, 77, 220, 1, SS_ETCHEDHORZ
    LTEXT "Hlavní vlastnosti:", IDC_STATIC, 10, 83, 220, 10
    LTEXT "• UTF-8 prostý text (bez BOM) · automatické ukládání", IDC_STATIC, 20, 95, 210, 10
    LTEXT "• Zalamování řádků · vizuální Ř/Sl · přejít na řádek", IDC_STATIC, 20, 106, 210, 10
    LTEXT "• Hledání/Nahrazení s historií, zpět a escape sekvencemi", IDC_STATIC, 20, 117, 210, 10
    LTEXT "• Filtry a příkazy roury · vkládání šablon (F5)", IDC_STATIC, 20, 128, 210, 10
    LTEXT "• Uložení se zvýšenými právy (UAC) · obnovení relace", IDC_STATIC, 20, 139, 210, 10
    LTEXT "• Anglické + české UI · přístupné pro čtečky obrazovky", IDC_STATIC, 20, 150, 210, 10
    DEFPUSHBUTTON "OK", IDOK, 95, 162, 50, 14
END

// Find dialog (Phase 2.9)
IDD_FIND DIALOGEX 0, 0, 260, 120
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Najít"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    LTEXT           "&Co hledat:", IDC_STATIC, 7, 10, 50, 8
    COMBOBOX        IDC_FIND_WHAT, 60, 8, 130, 100, CBS_DROPDOWN | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Nahradit &čím:", IDC_REPLACE_WITH_LABEL, 7, 28, 50, 8
    COMBOBOX        IDC_REPLACE_WITH, 60, 26, 130, 100, CBS_DROPDOWN | CBS_AUTOHSCROLL | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "&Další →", IDC_FIND_NEXT_BTN, 197, 7, 56, 14
    PUSHBUTTON      "&Předchozí ←", IDC_FIND_PREV_BTN, 197, 24, 56, 14
    PUSHBUTTON      "&Nahradit", IDC_REPLACE_BTN, 197, 42, 56, 14
    PUSHBUTTON      "Nahradit &vše", IDC_REPLACE_ALL_BTN, 197, 59, 56, 14
    PUSHBUTTON      "Zavřít", IDC_CLOSE_BTN, 197, 99, 56, 14
    AUTOCHECKBOX    "Rozlišovat &velikost písmen", IDC_MATCH_CASE, 7, 48, 120, 10
    AUTOCHECKBOX    "&Celá slova", IDC_WHOLE_WORD, 7, 63, 80, 10
    AUTOCHECKBOX    "Použít &escape sekvence (\\n, \\t, \\xNN, \\uNNNN)", IDC_USE_ESCAPES, 7, 78, 180, 10
END

// Go to Line dialog (Phase 2.9.4)
IDD_GOTO DIALOGEX 0, 0, 200, 80
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Přejít na řádek"
FONT 8, "MS Shell Dlg", 400, 0
BEGIN
    LTEXT           "", IDC_GOTO_LABEL, 10, 12, 180, 8
    EDITTEXT        IDC_GOTO_LINE, 10, 25, 180, 14, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON   "Přejít", IDOK, 55, 50, 40, 14
    PUSHBUTTON      "Zrušit", IDCANCEL, 105, 50, 40, 14
END

// String Resources (Czech)
STRINGTABLE
BEGIN
    IDS_ERROR                    "Chyba"
